generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model CompanyWorkspace {
  id          String               @id @default(cuid())
  name        String
  industry    String
  description String
  tools       Json
  teams       Team[]
  roleCards   RoleCard[]
  workflows   Workflow[]
  events      UnderstandingEvent[]
  reports     Report[]
  createdAt   DateTime             @default(now())
}

model Team {
  id               String           @id @default(cuid())
  workspaceId      String
  name             String
  description      String
  responsibilities Json
  workspace        CompanyWorkspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  roleCards        RoleCard[]

  @@unique([workspaceId, name])
  @@index([workspaceId])
}

model RoleCard {
  id                       String           @id @default(cuid())
  workspaceId              String
  teamId                   String
  roleName                 String
  needsToUnderstand        Json
  commonMisunderstandings  Json
  requiredInputs           Json
  expectedOutputs          Json
  blockingQuestions        Json
  workspace                CompanyWorkspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  team                     Team             @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@unique([teamId, roleName])
  @@index([workspaceId])
}

model Workflow {
  id          String           @id @default(cuid())
  workspaceId String
  name        String
  sourceTeam  String
  targetTeam  String
  description String
  commonRisks Json
  workspace   CompanyWorkspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
}

model UnderstandingEvent {
  id                String           @id @default(cuid())
  workspaceId       String
  title             String
  safeSummary       String
  contentFingerprint String
  privacyMode       String           @default("safe")
  rawStored         Boolean          @default(false)
  inputType         String
  sourceRole        String
  targetRole        String
  targetTeam        String
  expectedReceiver  String
  packType          String
  probableIntent    String
  missingContext    Json
  risks             Json
  criticalQuestions Json
  recommendedOutput String
  status            String
  scores            Json
  createdAt         DateTime         @default(now())
  workspace         CompanyWorkspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  analysisResults   AnalysisResult[]

  @@index([workspaceId, status])
  @@index([workspaceId, packType])
}

model AnalysisResult {
  id                 String             @id @default(cuid())
  eventId            String
  safeSummary        String
  probableIntent     String
  targetReceiver     String
  meaningLossRisk    Float
  missingInformation Json
  assumptions        Json
  risks              Json
  criticalQuestions  Json
  recommendedActions Json
  recommendedOutput  String
  generatedArtifacts Json
  scores              Json
  event               UnderstandingEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@index([eventId])
}

model Report {
  id              String           @id @default(cuid())
  workspaceId     String
  reportType      String
  title           String
  summary         String
  findings        Json
  recommendations Json
  createdAt       DateTime         @default(now())
  workspace       CompanyWorkspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId, reportType])
}
